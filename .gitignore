dist/
node_modules/

# Runtime metric artefacts — generated by the factory at runtime, never committed.
# Schema docs (SCHEMA.md, README.md) are tracked.
#
# The prototype factory deliberately does NOT audit plans to disk (per
# WORK-2 brief — plans-to-disk audit is stripped). The .claude/plans
# directory exists in stamped workspaces only for symmetry with the
# production factory's layout; it is not populated by the chain.
.claude/metrics/*/

# Shared root assets that are also runtime state (not per-brief, but still
# generated by hooks / the factory).
.claude/metrics/.session-start.json
.claude/metrics/session-end.jsonl

# Per-developer overrides (not committed to the shared pack).
.claude/settings.local.json

# Local persistence scaffolds may produce SQLite / JSON state at demo runtime.
# These belong to the developer's local demo, not to the pack.
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
.demo-state/

# Secrets / credentials — never commit. The pack ships zero credentials by
# design (local-only demos, no real customer data), but contributor
# environments accumulate auth material. Belt and braces.
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
*.p12
*.pfx
*.crt
id_rsa
id_rsa.*
id_ecdsa
id_ecdsa.*
id_ed25519
id_ed25519.*
.npmrc
.netrc
secrets/
credentials.json
service-account*.json
gcp-key*.json
aws-credentials*

# OS / IDE noise
.DS_Store
Thumbs.db
.vscode/
.idea/
